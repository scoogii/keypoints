{
  "manifest_version": 3,
  "name": "Sift - Amazon Review Analyzer",
  "description": "Amazon review summarizer with the help of an AI assistant",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "version": "1.0",
  "permissions": [
    "activeTab",
    "identity",
    "storage",
    "cookies"
  ],
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.ca/*",
    "*://*.amazon.com.au/*",
    "*://*.amazon.de/*",
    "*://*.amazon.fr/*",
    "*://*.amazon.es/*",
    "*://*.amazon.it/*",
    "*://*.amazon.co.jp/*",
    "*://*.amazon.in/*",
    "*://*.amazon.com.br/*",
    "*://*.amazon.nl/*",
    "*://*.amazon.sg/*",
    "*://*.amazon.com.mx/*",
    "*://*.amazon.se/*",
    "*://*.amazon.pl/*",
    "*://*.amazon.ae/*",
    "*://*.amazon.sa/*",
    "*://*.amazon.com.tr/*"
  ],
  "content_scripts": [
    {
      "matches": [
          "*://*.amazon.com/*",
          "*://*.amazon.co.uk/*",
          "*://*.amazon.ca/*",
          "*://*.amazon.com.au/*",
          "*://*.amazon.de/*",
          "*://*.amazon.fr/*",
          "*://*.amazon.es/*",
          "*://*.amazon.it/*",
          "*://*.amazon.co.jp/*",
          "*://*.amazon.in/*",
          "*://*.amazon.com.br/*",
          "*://*.amazon.nl/*",
          "*://*.amazon.sg/*",
          "*://*.amazon.com.mx/*",
          "*://*.amazon.se/*",
          "*://*.amazon.pl/*",
          "*://*.amazon.ae/*",
          "*://*.amazon.sa/*",
          "*://*.amazon.com.tr/*"
        ],
      "js": ["content.js"]
    }
  ]
}
