{
  "manifest_version": 3,
  "name": "Sift - Amazon Review Analyzer",
  "description": "Amazon review summarizer with the help of an AI assistant",
  "action": {
    "default_popup": "popup.html"
  },
  "version": "1.0",
  "permissions": [
    "activeTab",
    "scripting",
    "identity",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.amazon.com/*", "*://*.amazon.co.uk/*", "*://*.amazon.ca/*", "*://*.amazon.com.au/*"],
      "js": ["content.js"]
    }
  ]
}
