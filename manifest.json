{
  "manifest_version": 3,
  "name": "Sift - Amazon Review Analyzer",
  "description": "Amazon review summarizer with the help of an AI assistant",
  "key": "",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "version": "1.0.1",
  "permissions": [
    "activeTab",
    "identity",
    "storage",
    "cookies"
  ],
  "oauth2": {
    "client_id": "420667401546-nu9ousj8ri77tdd0cisd3fll92640qpq.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile"
    ]
  },
  "host_permissions": [
    "*://*.amazon.com/*",
    "*://*.amazon.co.uk/*",
    "*://*.amazon.ca/*",
    "*://*.amazon.com.au/*",
    "*://*.amazon.de/*",
    "*://*.amazon.fr/*",
    "*://*.amazon.es/*",
    "*://*.amazon.it/*",
    "*://*.amazon.co.jp/*",
    "*://*.amazon.in/*",
    "*://*.amazon.com.br/*",
    "*://*.amazon.nl/*",
    "*://*.amazon.sg/*",
    "*://*.amazon.com.mx/*",
    "*://*.amazon.se/*",
    "*://*.amazon.pl/*",
    "*://*.amazon.ae/*",
    "*://*.amazon.sa/*",
    "*://*.amazon.com.tr/*",
    "https://charts.camelcamelcamel.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
          "*://*.amazon.com/*",
          "*://*.amazon.co.uk/*",
          "*://*.amazon.ca/*",
          "*://*.amazon.com.au/*",
          "*://*.amazon.de/*",
          "*://*.amazon.fr/*",
          "*://*.amazon.es/*",
          "*://*.amazon.it/*",
          "*://*.amazon.co.jp/*",
          "*://*.amazon.in/*",
          "*://*.amazon.com.br/*",
          "*://*.amazon.nl/*",
          "*://*.amazon.sg/*",
          "*://*.amazon.com.mx/*",
          "*://*.amazon.se/*",
          "*://*.amazon.pl/*",
          "*://*.amazon.ae/*",
          "*://*.amazon.sa/*",
          "*://*.amazon.com.tr/*"
        ],
      "js": ["content.js"]
    }
  ]
}
